# RelAI — environment configuration template
# Copy to .env.local in apps/web/ and fill in real values
# NEVER commit a populated .env.local

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_URL=https://relai.realty
NODE_ENV=development

# ============================================================================
# Auth — Clerk
# https://dashboard.clerk.com
# ============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================================================
# Database — Neon Postgres + pgvector
# https://console.neon.tech
# ============================================================================
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ============================================================================
# Storage — Cloudflare R2
# https://dash.cloudflare.com/?to=/:account/r2
# ============================================================================
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=relai-prod

# ============================================================================
# Async orchestration — Inngest
# https://app.inngest.com
# ============================================================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============================================================================
# Observability — Sentry
# https://sentry.io
# ============================================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=relai-web

# ============================================================================
# Inference vendors
# ============================================================================
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=

# Replicate (Jina CLIP v2 for photo embeddings) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# AssemblyAI (diarization) — https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# ============================================================================
# Recipe versions (bump triggers re-embed / re-extract via admin endpoint)
# ============================================================================
EMBEDDING_RECIPE_VERSION=v1
ONTOLOGY_VERSION=1

# ============================================================================
# Operational guardrails (anti-bug, NOT anti-user — see plan §11)
# ============================================================================
INFERENCE_MONTHLY_BUDGET_USD=500
INFERENCE_AGENT_DAILY_CAP_USD=50
INFERENCE_TASK_DAILY_CALL_CAP=50000

# ============================================================================
# Feature flags (defaults; runtime overrides via admin)
# ============================================================================
MATCH_EXPLANATIONS_ENABLED=true
PHOTO_PIPELINE_ENABLED=false
